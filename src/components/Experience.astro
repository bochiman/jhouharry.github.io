---
import { Image } from 'astro:assets';
import { experience } from '../data/experience';

const accentBar = (a: string) => (a === 'primary' ? 'bg-primary-var' : 'bg-secondary-var');
const periodCls = (a: string) =>
  a === 'primary'
    ? 'text-primary-var bg-primary-var/10 border-primary-var/20'
    : 'text-secondary-var bg-secondary-var/10 border-secondary-var/20';
const roleCls = (a: string) => (a === 'primary' ? 'text-main-var opacity-90' : 'text-primary-var');
---

<!-- 个人经历 (Experience) -->
<section id="experience" class="py-8 reveal">
  <h2 class="text-2xl font-bold mb-8 flex items-center gap-2 gradient-text">
    <i class="fas fa-code-branch text-secondary-var text-xl"></i>
    <span class="lang-en">Education & Experience</span><span class="lang-zh">教育与经历</span>
  </h2>

  <div class="space-y-6">
    {
      experience.map((e) => (
        <div class="exp-card bg-card-var rounded-xl shadow-sm border border-var p-6 transition-all duration-300 relative overflow-hidden group">
          <div class={`absolute top-0 left-0 w-1 h-full ${accentBar(e.accent)} transition-all duration-300 group-hover:w-2`} />
          <div class="flex flex-col sm:flex-row gap-6 items-start sm:items-center">
            <div class="w-16 h-16 flex-shrink-0 bg-white rounded-lg p-1 shadow-sm flex items-center justify-center">
              <Image src={e.logo} alt={`${e.org} Logo`} class="w-full h-full object-contain logo-img p-1" />
            </div>
            <div class="flex-1">
              <div class="flex flex-col md:flex-row md:items-center justify-between mb-1">
                <h3 class="text-xl font-bold text-main-var">
                  <span class="lang-en">{e.org}</span>
                  <span class="lang-zh">{e.orgZh}</span>
                </h3>
                <span class={`text-sm font-medium ${periodCls(e.accent)} px-3 py-1 rounded-full border mt-2 md:mt-0 inline-block w-fit`}>
                  <span class="lang-en">{e.periodEn}</span>
                  <span class="lang-zh">{e.periodZh}</span>
                </span>
              </div>
              <p class={`text-base font-medium ${roleCls(e.accent)} mb-2`}>
                <span class="lang-en">{e.roleEn}</span>
                <span class="lang-zh">{e.roleZh}</span>
              </p>
              <p class="text-sm text-muted-var leading-relaxed">
                <span class="lang-en">{e.descEn}</span>
                <span class="lang-zh">{e.descZh}</span>
              </p>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
