---
import { Image } from 'astro:assets';
import { personal } from '../data/personal';
---

<!-- 1. 关于我 (Hero Section) -->
<section id="about" class="py-12 md:py-20 flex flex-col md:flex-row items-center gap-10">
  <div class="w-48 h-48 md:w-64 md:h-64 flex-shrink-0 relative group animate-fade-in-up">
    <Image
      src={personal.avatar}
      alt="Profile Picture"
      width={400}
      height={400}
      class="w-full h-full object-cover rounded-full shadow-lg border-4 border-var z-10 relative transition-transform duration-500 group-hover:scale-105 group-hover:rotate-1"
    />
    <!-- 装饰性光晕 -->
    <div class="absolute inset-0 bg-primary-var opacity-20 rounded-full blur-xl scale-110 -z-10 group-hover:scale-125 group-hover:opacity-30 transition-all duration-500"></div>
  </div>

  <div class="flex-1 text-center md:text-left animate-fade-in-up delay-100">
    <h1 class="text-3xl md:text-5xl font-bold mb-2 gradient-text">
      <span class="lang-en">{personal.name}</span>
      <span class="lang-zh">{personal.nameZh}</span>
    </h1>
    <p class="text-lg md:text-xl text-muted-var mb-4 font-medium">
      <span class="lang-en">{personal.title}</span>
      <span class="lang-zh">{personal.titleZh}</span>
    </p>
    <div class="mb-6 text-base text-main-var opacity-80 flex items-center justify-center md:justify-start gap-2">
      <i class="fas fa-terminal text-secondary-var transform transition-transform hover:scale-125"></i>
      <span>
        <span class="lang-en">{personal.institution}</span>
        <span class="lang-zh">{personal.institutionZh}</span>
      </span>
    </div>

    <p class="text-lg leading-loose mb-6 text-justify text-main-var">
      <span class="lang-en" set:html={personal.bio} />
      <span class="lang-zh" set:html={personal.bioZh} />
    </p>

    <!-- 联系方式/社交链接 -->
    <div class="flex flex-wrap gap-4 justify-center md:justify-start animate-fade-in-up delay-200">
      {
        personal.links.map((l) => (
          <a
            href={l.href}
            {...(l.href.startsWith('http') ? { target: '_blank' } : {})}
            class="flex items-center gap-2 text-muted-var hover:text-primary-var transition-all duration-300 hover:-translate-y-1"
          >
            <i class={`${l.icon} text-lg`} />
            <span class="text-sm">{l.label}</span>
          </a>
        ))
      }
    </div>
  </div>
</section>
