---
import { news } from '../data/news';
---

<!-- 最新动态 (News) -->
<section id="news" class="py-8 reveal">
  <h2 class="text-2xl font-bold mb-6 flex items-center gap-2 gradient-text">
    <i class="fas fa-terminal text-secondary-var text-xl"></i>
    <span class="lang-en">Latest News</span><span class="lang-zh">最新动态</span>
  </h2>
  <div class="bg-card-var rounded-xl shadow-sm border border-var p-6 transition-colors duration-300">
    <ul class="space-y-6 pr-2 custom-scrollbar">
      {
        news.map((n) => (
          <li class="flex flex-col sm:flex-row gap-4">
            <div class="min-w-[90px] text-sm font-semibold text-secondary-var pt-1 shrink-0">{n.date}</div>
            <div class="text-main-var flex-1 min-w-0">
              <span class="lang-en" set:html={n.en} />
              <span class="lang-zh" set:html={n.zh} />
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
